{
  "name": "skillio-clone",
  "version": "1.0.0",
  "description": "Full-stack clone of HelloSkillio website with backend and frontend",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm --prefix backend run dev\" \"npm --prefix client run dev\"",
    "dev:fe": "npm --prefix client run dev",
    "dev:be": "npm --prefix backend run dev",
    "build": "npm --prefix client run build"
  },
  "keywords": [
    "skillio",
    "clone",
    "express",
    "frontend",
    "backend"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "mongoose": "^8.4.3",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.1",
    "nodemon": "^3.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
